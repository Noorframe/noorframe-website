<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHATTERBORN | ثمن الدم</title>
    <link rel="icon" type="image/png" href="favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@200;400;700&display=swap" rel="stylesheet">
    
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        :root {
            --bg: #050505;
            --ocre: #b8860b;
            --text: #d1d1d1;
            --transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body { 
            background-color: var(--bg);
            background-image: linear-gradient(rgba(5, 5, 5, 0.85), rgba(5, 5, 5, 0.85)), url("fond site 1.png");
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
            color: var(--text); 
            font-family: 'Cairo', sans-serif; 
            line-height: 1.8;
            overflow-x: hidden;
            direction: rtl; /* Force l'écriture de droite à gauche */
        }

        nav {
            position: absolute;
            top: 0; width: 100%;
            padding: 35px 6%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: linear-gradient(to bottom, rgba(5,5,5,0.9), transparent);
        }

        .studio-name { font-size: 0.9rem; letter-spacing: 2px; font-weight: 200; color: #fff; }

        .nav-links { display: flex; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; font-size: 0.8rem;
            margin-right: 40px; opacity: 0.5; transition: var(--transition);
        }
        .nav-links a:hover { opacity: 1; color: var(--ocre); }

        header {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            background: linear-gradient(rgba(5, 5, 5, 0.4), rgba(5, 5, 5, 0.6)), url("SHATTERBORN LOGO FOG.png"); 
            background-size: cover;
            background-position: center;
        }

        .fade-bridge {
            width: 100%; height: 400px; 
            background: linear-gradient(to bottom, transparent, #050505);
            margin-top: -400px; position: relative; z-index: 10;
        }

        .main-logo {
            width: 85%; max-width: 700px; z-index: 10;
            filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.1));
            animation: logoEntrance 4s ease-out;
        }

        @keyframes logoEntrance {
            from { opacity: 0; transform: scale(1.1); filter: blur(20px); }
            to { opacity: 1; transform: scale(1); filter: blur(0); }
        }

        .section-reveal { 
            padding: 100px 5% 150px;
            max-width: 1400px;
            margin: auto;
            opacity: 0; 
            transform: translateY(50px); 
            transition: var(--transition);
        }
        .section-reveal.active { opacity: 1; transform: translateY(0); }

        h2 {
            font-family: 'Amiri', serif; font-size: clamp(2.2rem, 5vw, 3.8rem);
            color: #fff; font-weight: 700; margin-bottom: 40px; line-height: 1.2;
        }

        .accent-line {
            width: 80px; height: 1px; background: linear-gradient(to left, var(--ocre), transparent);
            margin-bottom: 40px;
        }

        .narrative-p { 
            font-size: 1.2rem; 
            max-width: 750px;
            margin-bottom: 25px; 
            font-weight: 300; 
            opacity: 0.9; 
        }

        .grid-cinematic { 
            display: grid; 
            grid-template-columns: 1fr 1.2fr;
            gap: 5vw;
            align-items: center; 
            width: 100%;
        }

        .visual-frame {
            width: 100%;
            aspect-ratio: 16/9;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .visual-frame img { width: 100%; height: 100%; object-fit: cover; transition: 0.8s ease; }

        .platforms-section {
            text-align: center; padding: 100px 10%; background: rgba(8, 8, 8, 0.4);
            border-top: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);
        }

        .platform-icons {
            display: flex; justify-content: center; gap: 60px; margin-top: 40px; flex-wrap: wrap;
        }

        .platform-item { 
            display: flex; flex-direction: column; gap: 15px; align-items: center; width: 120px; opacity: 0.7;
        }
        iconify-icon { font-size: 2.8rem; color: #fff; }

        footer {
            padding: 100px 10% 50px; text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-logo { font-family: 'Amiri', serif; font-size: 2.2rem; color: #fff; margin-bottom: 10px; }

        .lang-switcher {
            margin-right: 30px; font-size: 0.8rem;
            display: inline-flex; align-items: center;
        }
        .lang-switcher span.active { color: var(--ocre); font-weight: bold; }
        .lang-switcher a { text-decoration: none; color: inherit; opacity: 0.5; padding: 0 10px; }

        @media (max-width: 1024px) {
            nav { padding: 20px 5%; flex-direction: column; position: fixed; background: rgba(5, 5, 5, 0.98); }
            .nav-links { flex-wrap: wrap; justify-content: center; gap: 15px; }
            .nav-links a { margin-right: 0; font-size: 12px; padding: 5px; }
            .grid-cinematic { grid-template-columns: 1fr; }
            .section-reveal { padding: 120px 8% 80px; }
            h2 { text-align: right; font-size: 2.2rem !important; }
        }
    </style>
</head>
<body>

    <nav>
        <div class="studio-name">نورفريم إنتراكتيف</div>
        <div class="nav-links">
            <a href="#description">الكون</a>
            <a href="#studio">الاستوديو</a>
            <a href="#platforms">المنصات</a>
            <a href="#contact">اتصل بنا</a>
            <span class="lang-switcher">
                <a href="index.html" style="display: flex; align-items: center; gap: 6px;">
                    <iconify-icon icon="circle-flags:fr" style="font-size: 14px;"></iconify-icon>FR
                </a>|
                <a href="en.html" style="display: flex; align-items: center; gap: 6px;">
                    <iconify-icon icon="circle-flags:uk" style="font-size: 14px;"></iconify-icon>EN
                </a>|
                <span class="active" style="display: flex; align-items: center; gap: 6px;">
                    <iconify-icon icon="circle-flags:dz" style="font-size: 14px;"></iconify-icon>عربي
                </span>
            </span>
        </div>
    </nav>

    <header>
        <img src="LOGO SHATTERBORN 1.png" alt="Shatterborn" class="main-logo">
    </header>
    <div class="fade-bridge"></div>

    <section id="description" class="section-reveal">
        <div class="accent-line"></div>
        <div class="grid-cinematic">
            <div>
                <h2>حيث لا يموت الماضي أبداً</h2>
                <p class="narrative-p">تغمرك لعبة Shatterborn: ثمن الدم في أجواء إفريقيا الرومانية الغامضة، حيث لا تزال أنقاض الحضارات القديمة تحمل آثار قوة محرمة منذ الأزل.</p>
                <p class="narrative-p">تجسد دور "إسـران"، التيتان الذي يعيش في الظلال مسكوناً بماضٍ محطم. عندما يظهر "الأوبسكوريس" من جديد، لا يجد مفراً من العودة إلى الطريق واقتفاء أثر الحقيقة المدفونة منذ قرون.</p>
            </div>
            <div class="visual-frame">
                <img src="letsgo.png" alt="Shatterborn Art">
            </div>
        </div>
    </section>

    <section id="studio" class="section-reveal">
        <div class="accent-line"></div>
        <div class="grid-cinematic">
            <div class="visual-frame">
                <img src="visuaal.png" alt="Noorframe Vision">
            </div>
            <div>
                <h2>من نحن؟</h2>
                <p class="narrative-p">تأسس استوديو "نورفريم إنتراكتيف" في عام 2026، وهو استوديو مستقل مخصص لابتكار تجارب ألعاب فردية فاخرة لأجهزة الكمبيوتر ومنصات الألعاب المنزلية.</p>
                <p class="narrative-p">طموحنا هو بناء عوالم لا تُنسى وقصص تترك أثراً دائماً، مع الحفاظ على دقة التنفيذ والحرية الإبداعية التي تميز الاستوديوهات المستقلة.</p>
            </div>
        </div>
    </section>

    <section id="platforms" class="platforms-section section-reveal">
        <div class="accent-line" style="margin: 0 auto 40px;"></div>
        <h2>متوفر قريباً</h2>
        <div class="platform-icons">
            <div class="platform-item"><iconify-icon icon="simple-icons:playstation"></iconify-icon><span>PlayStation</span></div>
            <div class="platform-item"><iconify-icon icon="simple-icons:xbox"></iconify-icon><span>Xbox Series</span></div>
            <div class="platform-item"><iconify-icon icon="simple-icons:steam"></iconify-icon><span>Steam</span></div>
            <div class="platform-item"><iconify-icon icon="simple-icons:epicgames"></iconify-icon><span>Epic Games</span></div>
        </div>
    </section>

    <footer id="contact">
        <div class="footer-logo">Shatterborn</div>
        <a href="mailto:contact@noorframeinteractive.com" style="color: var(--ocre); text-decoration: none; font-size: 0.9rem;">contact@noorframeinteractive.com</a>
        <div style="display: flex; justify-content: center; gap: 40px; margin: 40px 0;">
            <a href="https://www.youtube.com/@noorframeinteractive" target="_blank" style="color: white; font-size: 1.5rem;"><i class="fab fa-youtube"></i></a>
            <a href="https://x.com/noorframe" target="_blank" style="color: white; font-size: 1.5rem;"><i class="fa-brands fa-x-twitter"></i></a>
            <a href="https://www.instagram.com/noorframeinteractive" target="_blank" style="color: white; font-size: 1.5rem;"><i class="fab fa-instagram"></i></a>
        </div>
        <p style="font-size: 0.7rem; opacity: 0.3; letter-spacing: 1px;">© 2026 Noorframe Interactive. صُنع بشغف في الجزائر.</p>
    </footer>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.15 });
        document.querySelectorAll('.section-reveal').forEach(s => observer.observe(s));
    </script>
</body>
</html>
